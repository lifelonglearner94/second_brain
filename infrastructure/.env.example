# Second Brain runtime-secret contract (ADR-0004, issue #30).
#
# Single source of truth for every runtime-secret/config key the system
# consumes across all slices. Values are INTENTIONALLY BLANK — fill them in on
# the VPS host as `infrastructure/.env` (gitignored, never committed). Later
# slices read keys from `.env`; they do NOT extend this contract ad hoc.
#
# GHA-blind (ADR-0004): the real `.env` is placed manually once over SSH and is
# never read, written, or referenced by CI — GitHub Actions ships only code.
# This `.env.example` carries no values and IS committed, so it is safe to
# track and ship. Secrets vs config is marked per line.
#
# Legend:  [SECRET] = genuine credential, must never be logged/baked/committed.
#          [config] = non-secret runtime configuration (often has a safe default).

# --- Backend runtime config --------------------------------------------------
HOST=                          # [config] bind host (default 0.0.0.0)
PORT=                          # [config] bind port (default 8080)
LOG_FORMAT=                    # [config] tracing format: json | plain (default json)
DATABASE_URL=                  # [config] SQLite path, e.g. /data/second_brain.db (NOT a secret)
RUST_LOG=                      # [config] tracing filter, e.g. info,second_brain_backend=debug

# --- Gemini ------------------------------------------------------------------
GEMINI_API_KEY=                # [SECRET] Gemini API key — the only genuine runtime secret today
GEMINI_TEXT_MODEL=             # [config] text/chat model id (backend default applies if blank)
GEMINI_EMBED_MODEL=            # [config] embedding model id (backend default applies if blank)
GEMINI_REASONING_EFFORT=       # [config] thinking budget: minimal | low | medium | high (default in backend)

# --- Gemini free-tier fallback circuit breaker (issue #86) -------------------
GEMINI_TEXT_MODEL_FALLBACK=    # [config] fallback text model when the primary trips 429s (default gemini-3.1-flash-lite)
GEMINI_FALLBACK_MAX_ATTEMPTS=  # [config] consecutive transient failures that open the circuit (default 5)
GEMINI_FALLBACK_COOLDOWN_SECS= # [config] how long the circuit stays open before a half-open probe (default 3600)

# --- Cloudflare R2 / Litestream — Brain Replica (ADR-0002, slice #32) --------
LITESTREAM_ACCESS_KEY_ID=      # [SECRET] R2 access key id for WAL replication
LITESTREAM_SECRET_ACCESS_KEY=  # [SECRET] R2 secret access key for WAL replication
LITESTREAM_ENDPOINT=           # [config] R2 S3 endpoint, e.g. https://<account>.r2.cloudflarestorage.com
LITESTREAM_BUCKET=             # [config] R2 bucket name holding the Brain Replica

# --- Health Push / ntfy (ADR-0005, slice #33) --------------------------------
NTFY_WEBHOOK_URL=              # [SECRET] ntfy.sh push endpoint (private topic + auth embedded in URL)

# --- WebAuthn relying party --------------------------------------------------
WEBAUTHN_RP_ID=                # [config] effective domain of WEBAUTHN_RP_ORIGIN (default localhost)
WEBAUTHN_RP_NAME=              # [config] human-friendly RP name shown by authenticators (default "Second Brain")
WEBAUTHN_RP_ORIGIN=            # [config] canonical origin, e.g. https://brain.example.com
