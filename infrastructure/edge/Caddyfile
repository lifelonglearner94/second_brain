{
	# Local-dev Caddyfile (ADR-0001). Auto-HTTPS is OFF: the site address is
	# `:80` (no hostname), so Caddy does not attempt ACME / TLS — `docker
	# compose up` is demoable on a laptop. On the VPS a per-host Caddyfile with
	# auto-HTTPS is swapped in at deploy time (#31). `admin off` keeps the
	# Edge a Zero-Trust Image (ADR-0004): no control-plane listener.
	admin off
}

:80 {
	# /api/* -> Backend (ADR-0006: internal-only, no host port). handle_path
	# strips the /api prefix: the PWA calls /api/health, the Backend serves
	# /health (routes are mounted at the Backend's root, not under /api).
	handle_path /api/* {
		reverse_proxy http://backend:8080
	}

	# PWA Bundle (ADR-0001): baked into the image at /srv, served by
	# file_server. try_files falls back to /index.html for client-side
	# routes not materialized as static files.
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
